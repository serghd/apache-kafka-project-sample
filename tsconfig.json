{
	"compilerOptions": {
      "rootDir": "./src",
		"outDir": "./dist",
		"target": "ESNext",
      "types": ["node"],
		"strict": true,
      "moduleResolution": "NodeNext",
      "module": "NodeNext",
		"noImplicitReturns": false,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"esModuleInterop": true,
		"allowJs": true
	},
	"include": ["src"],
	"exclude": ["node_modules"]
}
